# Grok2API environment example
#
# 用法：
# 1. 复制为 .env 后按需修改
# 2. 启动期 / 部署期变量放这里
# 3. 常规运行时配置优先改 ${DATA_DIR}/config.toml


# ==================== 基础运行 ====================
TZ=Asia/Shanghai
LOG_LEVEL=INFO
# 写入本地文件日志
LOG_FILE_ENABLED=true
# 账号目录增量同步间隔（秒）
ACCOUNT_SYNC_INTERVAL=30


# ==================== Web 服务 / Docker Compose ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1

# Docker Compose 宿主机映射端口
HOST_PORT=8000


# ==================== 账号存储（启动期） ====================
# 第一阶段仅支持：local | mysql
ACCOUNT_STORAGE=local

# mysql: Go MySQL DSN
# ACCOUNT_MYSQL_URL=user:password@tcp(127.0.0.1:3306)/grok2api?charset=utf8mb4&parseTime=True&loc=Local

# SQL 连接池（mysql / postgresql 模式，以下均为默认值，无需改动即可生效）
# ACCOUNT_SQL_POOL_SIZE=5
# ACCOUNT_SQL_MAX_OVERFLOW=10
# ACCOUNT_SQL_POOL_TIMEOUT=30
# ACCOUNT_SQL_POOL_RECYCLE=1800


# ==================== 可选：本地数据 / 日志目录 ====================
DATA_DIR=./data
LOG_DIR=./logs
